@model ClothingShop.Models.SupportTicket
@{
    ViewData["Title"] = "Chi tiết yêu cầu hỗ trợ";
}

<div class="container py-5" style="padding-bottom: 100px !important;">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <!-- Header -->
            <div class="card shadow-sm mb-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="flex-grow-1">
                            <h3 class="fw-bold mb-2">
                                <i class="fas fa-ticket-alt text-primary me-2"></i>@Model.Subject
                            </h3>
                            <div class="d-flex flex-wrap gap-3">
                                <small class="text-muted">
                                    <i class="fas fa-hashtag me-1"></i>Mã: <strong>#@Model.Id</strong>
                                </small>
                                <small class="text-muted">
                                    <i class="far fa-calendar me-1"></i>Tạo lúc: <strong>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</strong>
                                </small>
                                @if (Model.UpdatedAt.HasValue)
                                {
                                    <small class="text-muted">
                                        <i class="far fa-clock me-1"></i>Cập nhật: <strong>@Model.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</strong>
                                    </small>
                                }
                            </div>
                        </div>
                        <div>
                            @if (Model.Status == "Mở")
                            {
                                <span class="badge bg-success fs-6 px-3 py-2">
                                    <i class="fas fa-circle me-1" style="font-size: 0.5rem;"></i>@Model.Status
                                </span>
                            }
                            else if (Model.Status == "Đang xử lý")
                            {
                                <span class="badge bg-warning text-dark fs-6 px-3 py-2">
                                    <i class="fas fa-circle me-1" style="font-size: 0.5rem;"></i>@Model.Status
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary fs-6 px-3 py-2">
                                    <i class="fas fa-circle me-1" style="font-size: 0.5rem;"></i>@Model.Status
                                </span>
                            }
                        </div>
                    </div>
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">
                        <i class="fas fa-arrow-left me-1"></i>Quay lại danh sách
                    </a>
                </div>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- Danh sách tin nhắn -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="fas fa-comments me-2"></i>Cuộc trò chuyện
                        <span class="badge bg-primary ms-2">@Model.Messages.Count tin nhắn</span>
                    </h5>
                </div>
                <div class="card-body p-4" style="max-height: 600px; overflow-y: auto; background-color: #f8f9fa;">
                    @foreach (var msg in Model.Messages.OrderBy(m => m.CreatedAt))
                    {
                        <div class="mb-4 @(msg.IsAdmin ? "text-end" : "")">
                            <div class="d-inline-block text-start" style="max-width: 75%;">
                                <div class="mb-1">
                                    <small class="text-muted">
                                        @if (msg.IsAdmin)
                                        {
                                            <i class="fas fa-user-shield me-1"></i>
                                            <strong>Admin</strong>
                                        }
                                        else
                                        {
                                            <i class="fas fa-user me-1"></i>
                                            <strong>@(msg.Sender?.FullName ?? "Bạn")</strong>
                                        }
                                        <span class="ms-2">@msg.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                    </small>
                                </div>
                                <div class="card @(msg.IsAdmin ? "bg-primary text-white" : "bg-white") shadow-sm">
                                    <div class="card-body p-3">
                                        <div style="white-space: pre-wrap;">@msg.Message</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Form gửi tin nhắn -->
            @if (Model.Status != "Đã đóng")
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-body p-4">
                        <h5 class="mb-3">
                            <i class="fas fa-reply me-2"></i>Gửi tin nhắn
                        </h5>

                        <form asp-action="SendMessage" method="post">
                            <input type="hidden" name="ticketId" value="@Model.Id" />

                            <div class="mb-3">
                                <textarea name="message" class="form-control" rows="4" required maxlength="2000"
                                      placeholder="Nhập tin nhắn của bạn..."></textarea>
                                <small class="text-muted">Tối đa 2000 ký tự</small>
                            </div>

                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-paper-plane me-2"></i>Gửi tin nhắn
                            </button>
                        </form>

                        <!-- Form đóng yêu cầu (tách riêng – không lồng form) -->
                        <form asp-action="Close" method="post" class="mt-3"
                              onsubmit="return confirm('Bạn có chắc muốn đóng yêu cầu này?')">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-danger">
                                <i class="fas fa-times-circle me-2"></i>Đóng yêu cầu
                            </button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-secondary shadow-sm">
                    <i class="fas fa-lock me-2"></i>
                    <strong>Yêu cầu đã đóng.</strong> Không thể gửi tin nhắn mới.
                </div>
            }
        </div>
    </div>
</div>
