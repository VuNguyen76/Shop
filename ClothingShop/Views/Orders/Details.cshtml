@model Order
@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold mb-0">
                    <i class="fas fa-file-invoice me-2"></i>Chi tiết đơn hàng #@Model.Id.ToString("D6")
                </h2>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>
            </div>

            <!-- Thông tin đơn hàng -->
            <div class="card shadow-sm mb-4">
                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-md-3 mb-3">
                            <small class="text-muted">Ngày đặt hàng</small>
                            <p class="mb-0 fw-bold">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                        <div class="col-md-3 mb-3">
                            <small class="text-muted">Trạng thái</small>
                            <p class="mb-0">
                                @{
                                    var badgeClass = Model.Status switch
                                    {
                                        "Chờ xác nhận" => "bg-warning text-dark",
                                        "Chờ lấy hàng" => "bg-info",
                                        "Chờ giao hàng" => "bg-primary",
                                        "Đã giao" => "bg-success",
                                        "Đã hủy" => "bg-danger",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass">@Model.Status</span>
                            </p>
                        </div>
                        <div class="col-md-3 mb-3">
                            <small class="text-muted">Tổng tiền</small>
                            <p class="mb-0 fw-bold text-danger fs-5">@Model.TotalAmount.ToString("N0")₫</p>
                        </div>
                        <div class="col-md-3 mb-3">
                            @if (Model.Status == "Chờ xác nhận" || Model.Status == "Chờ lấy hàng")
                            {
                                <button type="button" class="btn btn-danger w-100" data-bs-toggle="modal" data-bs-target="#cancelModal">
                                    <i class="fas fa-times me-2"></i>Hủy đơn
                                </button>
                            }
                            @if (Model.Status == "Chờ giao hàng")
                            {
                                <button type="button" class="btn btn-success w-100" data-bs-toggle="modal" data-bs-target="#confirmReceivedModal">
                                    <i class="fas fa-check-circle me-2"></i>Đã nhận hàng
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Timeline trạng thái -->
            <div class="card shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="mb-4">
                        <i class="fas fa-shipping-fast me-2"></i>Trạng thái đơn hàng
                    </h5>
                    @if (Model.Status == "Đã hủy")
                    {
                        <div class="alert alert-danger">
                            <i class="fas fa-times-circle me-2"></i>
                            <strong>Đơn hàng đã bị hủy</strong>
                        </div>
                    }
                    else
                    {
                        <div class="timeline">
                            <div class="timeline-item active">
                                <div class="timeline-icon">
                                    <i class="fas fa-check"></i>
                                </div>
                                <div class="timeline-content">
                                    <h6>Chờ xác nhận</h6>
                                    <small class="text-muted">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</small>
                                </div>
                            </div>
                            <div class="timeline-item @(Model.Status == "Chờ lấy hàng" || Model.Status == "Chờ giao hàng" || Model.Status == "Đã giao" ? "active" : "")">
                                <div class="timeline-icon">
                                    <i class="fas fa-box"></i>
                                </div>
                                <div class="timeline-content">
                                    <h6>Chờ lấy hàng</h6>
                                    <small class="text-muted">Đơn hàng đang được chuẩn bị</small>
                                </div>
                            </div>
                            <div class="timeline-item @(Model.Status == "Chờ giao hàng" || Model.Status == "Đã giao" ? "active" : "")">
                                <div class="timeline-icon">
                                    <i class="fas fa-truck"></i>
                                </div>
                                <div class="timeline-content">
                                    <h6>Chờ giao hàng</h6>
                                    <small class="text-muted">Đơn hàng đang trên đường giao</small>
                                </div>
                            </div>
                            <div class="timeline-item @(Model.Status == "Đã giao" ? "active" : "")">
                                <div class="timeline-icon">
                                    <i class="fas fa-check-circle"></i>
                                </div>
                                <div class="timeline-content">
                                    <h6>Đã giao</h6>
                                    <small class="text-muted">Giao hàng thành công</small>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Danh sách sản phẩm -->
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h5 class="mb-4">
                        <i class="fas fa-shopping-bag me-2"></i>Sản phẩm đã đặt
                    </h5>
                    <div class="table-responsive">
                        <table class="table">
                            <thead class="table-light">
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th class="text-center">Số lượng</th>
                                    <th class="text-end">Đơn giá</th>
                                    <th class="text-end">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center justify-content-between">
                                                <div class="d-flex align-items-center">
                                                    @if (item.Product != null)
                                                    {
                                                        <a href="@Url.Action("Details", "Products", new { id = item.ProductId })">
                                                            <img src="@item.Product.ImageUrl" alt="@item.ProductName" class="rounded me-3" style="width: 60px; height: 60px; object-fit: cover;">
                                                        </a>
                                                    }
                                                    else
                                                    {
                                                        <div class="bg-light rounded me-3" style="width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                                                            <i class="fas fa-image text-muted"></i>
                                                        </div>
                                                    }
                                                    <div>
                                                        <a href="@Url.Action("Details", "Products", new { id = item.ProductId })" class="text-decoration-none">
                                                            <p class="mb-0 fw-bold">@item.ProductName</p>
                                                        </a>
                                                    </div>
                                                </div>
                                                @if (Model.Status == "Đã giao")
                                                {
                                                    <a href="@Url.Action("Details", "Products", new { id = item.ProductId })#reviews" class="btn btn-sm btn-outline-warning">
                                                        <i class="fas fa-star me-1"></i>Đánh giá
                                                    </a>
                                                }
                                            </div>
                                        </td>
                                        <td class="text-center">@item.Quantity</td>
                                        <td class="text-end">@item.Price.ToString("N0")₫</td>
                                        <td class="text-end fw-bold">@((item.Price * item.Quantity).ToString("N0"))₫</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                @{
                                    decimal itemsTotal = Model.Items.Sum(i => i.Price * i.Quantity);
                                    decimal shippingFee = Model.TotalAmount - itemsTotal;
                                }
                                <tr>
                                    <td colspan="3" class="text-end fw-bold">Tạm tính:</td>
                                    <td class="text-end fw-bold">@itemsTotal.ToString("N0")₫</td>
                                </tr>
                                <tr>
                                    <td colspan="3" class="text-end fw-bold">Phí vận chuyển:</td>
                                    @if (shippingFee > 0)
                                    {
                                        <td class="text-end text-danger fw-bold">@shippingFee.ToString("N0")₫</td>
                                    }
                                    else
                                    {
                                        <td class="text-end text-success fw-bold">Miễn phí</td>
                                    }
                                </tr>
                                <tr>
                                    <td colspan="3" class="text-end fw-bold fs-5">Tổng cộng:</td>
                                    <td class="text-end text-danger fw-bold fs-5">@Model.TotalAmount.ToString("N0")₫</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .timeline {
        position: relative;
        padding-left: 50px;
    }
    
    .timeline-item {
        position: relative;
        padding-bottom: 30px;
        opacity: 0.5;
    }
    
    .timeline-item.active {
        opacity: 1;
    }
    
    .timeline-item:not(:last-child)::before {
        content: '';
        position: absolute;
        left: -35px;
        top: 40px;
        width: 2px;
        height: calc(100% - 20px);
        background: #ddd;
    }
    
    .timeline-item.active:not(:last-child)::before {
        background: #28a745;
    }
    
    .timeline-icon {
        position: absolute;
        left: -50px;
        top: 0;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #f8f9fa;
        border: 2px solid #ddd;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #6c757d;
    }
    
    .timeline-item.active .timeline-icon {
        background: #28a745;
        border-color: #28a745;
        color: white;
    }
</style>


<!-- Hiển thị lý do hủy nếu đơn đã bị hủy -->
@if (!string.IsNullOrEmpty(Model.CancelReason))
{
    <div class="card shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="alert alert-danger mb-0">
                <h5 class="alert-heading"><i class="fas fa-exclamation-circle me-2"></i>Lý do hủy đơn</h5>
                <p class="mb-2">@Model.CancelReason</p>
                <hr>
                <small class="text-muted">
                    Hủy bởi: @(Model.CancelledBy == "Admin" ? "Quản trị viên" : "Bạn") | 
                    Thời gian: @Model.CancelledAt?.ToString("dd/MM/yyyy HH:mm")
                </small>
            </div>
        </div>
    </div>
}

@await Html.PartialAsync("_CancelOrderModal", Model)

<!-- Modal xác nhận đã nhận hàng -->
<div class="modal fade" id="confirmReceivedModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">
                    <i class="fas fa-check-circle me-2"></i>Xác nhận đã nhận hàng
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="ConfirmReceived" method="post">
                <input type="hidden" name="orderId" value="@Model.Id" />
                <div class="modal-body">
                    <div class="text-center mb-3">
                        <i class="fas fa-box-open fa-4x text-success mb-3"></i>
                        <h5>Bạn đã nhận được hàng?</h5>
                        <p class="text-muted">
                            Vui lòng xác nhận khi bạn đã nhận được đơn hàng và kiểm tra sản phẩm.
                        </p>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times me-2"></i>Chưa nhận
                    </button>
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-check-circle me-2"></i>Xác nhận đã nhận
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ModalScripts")
}
