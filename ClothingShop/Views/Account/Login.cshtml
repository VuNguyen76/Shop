@{
    ViewData["Title"] = "Tài khoản của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="min-vh-100 bg-light d-flex align-items-center py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-6">
                <h2 class="text-center fw-bold text-uppercase mb-5">TÀI KHOẢN CỦA TÔI</h2>

                <!-- THÔNG BÁO -->
                @if (TempData.ContainsKey("Success"))
                {
                    <div class="alert alert-success text-center small">
                        @TempData["Success"]
                    </div>
                }
                @if (TempData.ContainsKey("Error"))
                {
                    <div class="alert alert-danger text-center small">
                        @TempData["Error"]
                    </div>
                }

                <!-- FORM ĐĂNG NHẬP -->
                <div class="bg-white p-5 rounded-4 shadow">
                    <h3 class="text-center fw-bold mb-4">ĐĂNG NHẬP</h3>
                    <form asp-action="Login" asp-controller="Account" method="post">
                        <input type="hidden" name="ReturnUrl" value="@ViewBag.ReturnUrl" />
                        <div class="mb-3">
                            <input type="email" name="Email" class="form-control form-control-lg"
                                   placeholder="EMAIL *" required autofocus />
                        </div>
                        <div class="mb-4 position-relative">
                            <input type="password" id="loginPassword" name="Password" class="form-control form-control-lg pe-5"
                                   placeholder="MẬT KHẨU *" required />
                            <span class="position-absolute end-0 top-50 translate-middle-y pe-3 cursor-pointer"
                                  onclick="togglePassword('loginPassword', this)">
                                <i class="fas fa-eye text-muted"></i>
                            </span>
                        </div>
                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-dark btn-lg text-uppercase fw-bold">
                                ĐĂNG NHẬP
                            </button>
                        </div>
                        <div class="d-flex justify-content-between align-items-center small">
                            <div>
                                Bạn chưa có tài khoản?
                                <a asp-controller="Account" asp-action="Register" asp-route-returnUrl="@ViewBag.ReturnUrl" class="text-dark fw-bold text-decoration-none">
                                    ĐĂNG KÝ
                                </a>
                            </div>
                            <div>
                                <a asp-action="ForgotPassword" class="text-muted text-decoration-none">Quên mật khẩu?</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control::placeholder {
        color: #999;
        font-weight: 400;
    }
    .btn-dark, .btn-secondary {
        border: none;
        border-radius: 8px;
    }
    .btn-dark {
        background-color: #000;
    }
        .btn-dark:hover {
            background-color: #333;
        }
    .btn-secondary {
        background-color: #999;
    }
        .btn-secondary:hover {
            background-color: #666;
        }
    .shadow {
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    }
    .cursor-pointer {
        cursor: pointer;
        user-select: none;
    }
</style>

@section Scripts {
    <script>
        // Hàm chuyển đổi hiện/ẩn mật khẩu
        function togglePassword(inputId, icon) {
            const input = document.getElementById(inputId);
            const isPassword = input.type === "password";
            input.type = isPassword ? "text" : "password";
            icon.innerHTML = isPassword
                ? '<i class="fas fa-eye-slash text-muted"></i>'
                : '<i class="fas fa-eye text-muted"></i>';
        }
    </script>
}