@model Order
@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body p-5 text-center">
                    <!-- Icon thành công -->
                    <div class="mb-4">
                        <i class="fas fa-check-circle text-success" style="font-size: 80px;"></i>
                    </div>

                    <h2 class="fw-bold mb-3">Đặt hàng thành công!</h2>
                    <p class="text-muted mb-4">Cảm ơn bạn đã mua hàng tại ClothingShop</p>

                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        Mã đơn hàng của bạn: <strong>#@Model.Id.ToString("D6")</strong>
                    </div>

                    <!-- Thông tin đơn hàng -->
                    <div class="card bg-light mb-4">
                        <div class="card-body">
                            <div class="row text-start">
                                <div class="col-6 mb-3">
                                    <small class="text-muted">Ngày đặt:</small>
                                    <p class="mb-0 fw-bold">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                                </div>
                                <div class="col-6 mb-3">
                                    <small class="text-muted">Trạng thái:</small>
                                    <p class="mb-0">
                                        <span class="badge bg-warning">@Model.Status</span>
                                    </p>
                                </div>
                                <div class="col-12">
                                    <small class="text-muted">Tổng tiền:</small>
                                    <h4 class="text-danger mb-0">@Model.TotalAmount.ToString("N0")₫</h4>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Danh sách sản phẩm -->
                    <div class="text-start mb-4">
                        <h5 class="mb-3">Sản phẩm đã đặt:</h5>
                        @foreach (var item in Model.Items)
                        {
                            <div class="d-flex align-items-center mb-3 pb-3 border-bottom">
                                @if (item.Product != null)
                                {
                                    <img src="@item.Product.ImageUrl" alt="@item.ProductName" 
                                         class="rounded me-3" 
                                         style="width: 60px; height: 60px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="bg-light rounded me-3 d-flex align-items-center justify-content-center" 
                                         style="width: 60px; height: 60px;">
                                        <i class="fas fa-image text-muted"></i>
                                    </div>
                                }
                                <div class="flex-grow-1">
                                    <p class="mb-1 fw-bold">@item.ProductName</p>
                                    <small class="text-muted">Số lượng: @item.Quantity</small>
                                </div>
                                <p class="mb-0 fw-bold text-danger">@((item.Price * item.Quantity).ToString("N0"))₫</p>
                            </div>
                        }
                    </div>

                    <!-- Thông báo -->
                    <div class="alert alert-success mb-4">
                        <i class="fas fa-bell me-2"></i>
                        Chúng tôi sẽ liên hệ với bạn sớm nhất để xác nhận đơn hàng
                    </div>

                    <!-- Nút hành động -->
                    <div class="d-grid gap-2">
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-primary btn-lg">
                            <i class="fas fa-file-alt me-2"></i>Xem chi tiết đơn hàng
                        </a>
                        <a asp-action="Index" class="btn btn-outline-dark">
                            <i class="fas fa-list me-2"></i>Xem tất cả đơn hàng
                        </a>
                        <a asp-controller="Products" asp-action="Index" class="btn btn-outline-dark">
                            <i class="fas fa-shopping-bag me-2"></i>Tiếp tục mua sắm
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
