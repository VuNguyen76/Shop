@model ClothingShop.Models.Product
@{
    ViewData["Title"] = "Sửa sản phẩm";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    
    // Parse JSON cho Size và Color
    var sizes = new List<string>();
    var colors = new List<string>();
    
    try
    {
        if (!string.IsNullOrEmpty(Model.Size))
            sizes = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.Size) ?? new List<string>();
        if (!string.IsNullOrEmpty(Model.Color))
            colors = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.Color) ?? new List<string>();
    }
    catch { }
}

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-edit me-2"></i>Sửa sản phẩm: @Model.Name</h5>
            </div>
            <div class="card-body">
                <form action="/Admin/Products/Update" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ImageUrl" />
                    <input type="hidden" asp-for="AdditionalImages" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <!-- Giữ nguyên Price và Quantity (không cho phép sửa) -->
                    <input type="hidden" asp-for="Price" />
                    <input type="hidden" asp-for="Quantity" />
                    
                    <div class="row g-3">
                        <!-- Tên sản phẩm -->
                        <div class="col-md-12">
                            <label class="form-label">Tên sản phẩm <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" required />
                        </div>

                        <!-- Mô tả -->
                        <div class="col-md-12">
                            <label class="form-label">Mô tả</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        </div>

                        <!-- Danh mục -->
                        <div class="col-md-6">
                            <label class="form-label">Danh mục <span class="text-danger">*</span></label>
                            <select asp-for="Category" class="form-select" required>
                                <option value="">-- Chọn danh mục --</option>
                                @if (ViewBag.Categories != null)
                                {
                                    foreach (var cat in ViewBag.Categories)
                                    {
                                        <option value="@cat.Name">@cat.Name</option>
                                    }
                                }
                            </select>
                        </div>

                        <!-- Giới tính -->
                        <div class="col-md-6">
                            <label class="form-label">Giới tính <span class="text-danger">*</span></label>
                            <select asp-for="Gender" class="form-select" required>
                                <option value="Nam">Nam</option>
                                <option value="Nữ">Nữ</option>
                                <option value="Unisex">Unisex</option>
                            </select>
                        </div>

                        <!-- Size -->
                        <div class="col-md-12">
                            <label class="form-label">Size <span class="text-danger">*</span></label>
                            <div class="border rounded p-3 bg-light">
                                @foreach (var size in new[] { "S", "M", "L", "XL", "XXL", "XXXL", "Freesize", "Không có size" })
                                {
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="checkbox" name="sizes" value="@size" 
                                               id="size@size.Replace(" ", "")" checked="@sizes.Contains(size)">
                                        <label class="form-check-label" for="size@size.Replace(" ", "")">@size</label>
                                    </div>
                                }
                            </div>
                            <input type="hidden" asp-for="Size" id="sizeHidden" />
                            <small class="text-muted">Chọn "Không có size" cho phụ kiện, nón, balo...</small>
                        </div>

                        <!-- Màu sắc -->
                        <div class="col-md-12">
                            <label class="form-label">Màu sắc <span class="text-danger">*</span></label>
                            <div class="border rounded p-3 bg-light">
                                @foreach (var color in new[] { "Đen", "Trắng", "Xám", "Đỏ", "Xanh dương", "Xanh lá", "Vàng", "Hồng", "Nâu" })
                                {
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="checkbox" name="colors" value="@color" 
                                               id="color@color.Replace(" ", "")" checked="@colors.Contains(color)">
                                        <label class="form-check-label" for="color@color.Replace(" ", "")">@color</label>
                                    </div>
                                }
                            </div>
                            <input type="hidden" asp-for="Color" id="colorHidden" />
                        </div>

                        <!-- Ảnh hiện tại -->
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="col-md-12">
                                <label class="form-label">Ảnh hiện tại</label>
                                <div>
                                    <img src="@Model.ImageUrl" alt="@Model.Name" class="img-thumbnail" 
                                         style="max-width: 200px; image-rendering: -webkit-optimize-contrast; image-rendering: crisp-edges;">
                                </div>
                            </div>
                        }

                        <!-- Ảnh phụ hiện tại -->
                        @if (!string.IsNullOrEmpty(Model.AdditionalImages))
                        {
                            var additionalImages = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.AdditionalImages);
                            if (additionalImages != null && additionalImages.Count > 0)
                            {
                                <div class="col-md-12">
                                    <label class="form-label">Ảnh phụ hiện tại</label>
                                    <div class="row g-2">
                                        @foreach (var img in additionalImages)
                                        {
                                            <div class="col-md-2">
                                                <img src="@img" alt="Additional" class="img-thumbnail" 
                                                     style="width: 100%; height: 100px; object-fit: cover; image-rendering: auto;">
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }

                        <!-- Upload ảnh mới -->
                        <div class="col-md-12">
                            <label class="form-label">Thay đổi ảnh chính</label>
                            <input type="file" name="imageFile" class="form-control" accept="image/*,.avif" />
                            <small class="text-muted">Để trống nếu không muốn thay đổi</small>
                        </div>

                        <!-- Upload ảnh phụ mới -->
                        <div class="col-md-12">
                            <label class="form-label">Thay đổi ảnh phụ (tối đa 5 ảnh)</label>
                            <input type="file" name="additionalImages" class="form-control" accept="image/*,.avif" multiple />
                            <small class="text-muted">Để trống nếu không muốn thay đổi. Nếu upload mới sẽ thay thế toàn bộ ảnh cũ.</small>
                        </div>

                        <!-- Nút submit -->
                        <div class="col-md-12">
                            <hr>
                            <div class="d-flex justify-content-between">
                                <a asp-action="Products" class="btn btn-secondary">
                                    <i class="fas fa-arrow-left me-1"></i>Quay lại
                                </a>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save me-1"></i>Cập nhật sản phẩm
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Xử lý checkbox size và màu
        function updateHiddenFields() {
            const sizeCheckboxes = document.querySelectorAll('input[name="sizes"]:checked');
            const sizes = Array.from(sizeCheckboxes).map(cb => cb.value);
            document.getElementById('sizeHidden').value = JSON.stringify(sizes);

            const colorCheckboxes = document.querySelectorAll('input[name="colors"]:checked');
            const colors = Array.from(colorCheckboxes).map(cb => cb.value);
            document.getElementById('colorHidden').value = JSON.stringify(colors);
        }

        document.addEventListener('DOMContentLoaded', function() {
            const allCheckboxes = document.querySelectorAll('input[name="sizes"], input[name="colors"]');
            allCheckboxes.forEach(cb => {
                cb.addEventListener('change', updateHiddenFields);
            });

            // Validate khi submit
            document.querySelector('form').addEventListener('submit', function(e) {
                updateHiddenFields();
            });
        });
    </script>
}
