@model List<Order>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Header -->
            <div class="text-center mb-4">
                <h2 class="fw-bold mb-2">
                    <i class="fas fa-shopping-bag me-2"></i>ĐƠN HÀNG CỦA TÔI
                </h2>
            </div>

            <!-- Tabs -->
            <ul class="nav nav-pills nav-fill mb-4" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="processing-tab" data-bs-toggle="pill" data-bs-target="#processing" type="button" role="tab">
                        <i class="fas fa-clock me-2"></i>Đang xử lý
                        <span class="badge bg-primary ms-2">@Model.Count(o => o.Status != "Đã giao" && o.Status != "Đã hủy")</span>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="completed-tab" data-bs-toggle="pill" data-bs-target="#completed" type="button" role="tab">
                        <i class="fas fa-check-circle me-2"></i>Đã giao
                        <span class="badge bg-success ms-2">@Model.Count(o => o.Status == "Đã giao")</span>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="cancelled-tab" data-bs-toggle="pill" data-bs-target="#cancelled" type="button" role="tab">
                        <i class="fas fa-times-circle me-2"></i>Đã hủy
                        <span class="badge bg-danger ms-2">@Model.Count(o => o.Status == "Đã hủy")</span>
                    </button>
                </li>
            </ul>

            <div class="tab-content">
                <!-- Tab Đang xử lý -->
                <div class="tab-pane fade show active" id="processing" role="tabpanel">
                    @{
                        var processingOrders = Model.Where(o => o.Status != "Đã giao" && o.Status != "Đã hủy").ToList();
                    }
                    @if (!processingOrders.Any())
                    {
                        <div class="card shadow-sm text-center py-5">
                            <div class="card-body">
                                <i class="fas fa-box-open fa-5x text-muted mb-4"></i>
                                <h4 class="mb-3">Không có đơn hàng đang xử lý</h4>
                                <p class="text-muted mb-4">Các đơn hàng của bạn sẽ hiển thị ở đây</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        @foreach (var order in processingOrders)
                        {
                            @await Html.PartialAsync("_OrderCard", order)
                        }
                    }
                </div>

                <!-- Tab Đã giao -->
                <div class="tab-pane fade" id="completed" role="tabpanel">
                    @{
                        var completedOrders = Model.Where(o => o.Status == "Đã giao").ToList();
                    }
                    @if (!completedOrders.Any())
                    {
                        <div class="card shadow-sm text-center py-5">
                            <div class="card-body">
                                <i class="fas fa-box-open fa-5x text-muted mb-4"></i>
                                <h4 class="mb-3">Chưa có đơn hàng nào hoàn thành</h4>
                                <p class="text-muted mb-4">Các đơn hàng đã giao sẽ hiển thị ở đây</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        @foreach (var order in completedOrders)
                        {
                            @await Html.PartialAsync("_OrderCard", order)
                        }
                    }
                </div>

                <!-- Tab Đã hủy -->
                <div class="tab-pane fade" id="cancelled" role="tabpanel">
                    @{
                        var cancelledOrders = Model.Where(o => o.Status == "Đã hủy").ToList();
                    }
                    @if (!cancelledOrders.Any())
                    {
                        <div class="card shadow-sm text-center py-5">
                            <div class="card-body">
                                <i class="fas fa-box-open fa-5x text-muted mb-4"></i>
                                <h4 class="mb-3">Không có đơn hàng bị hủy</h4>
                                <p class="text-muted mb-4">Các đơn hàng đã hủy sẽ hiển thị ở đây</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        @foreach (var order in cancelledOrders)
                        {
                            @await Html.PartialAsync("_OrderCard", order)
                        }
                    }
                </div>
            </div>

            @if (!Model.Any())
            {
                <div class="card shadow-sm text-center py-5">
                    <div class="card-body">
                        <i class="fas fa-box-open fa-5x text-muted mb-4"></i>
                        <h4 class="mb-3">Bạn chưa có đơn hàng nào</h4>
                        <p class="text-muted mb-4">Hãy khám phá các sản phẩm tuyệt vời của chúng tôi</p>
                        <a asp-controller="Products" asp-action="Index" class="btn btn-primary btn-lg">
                            <i class="fas fa-shopping-bag me-2"></i>Mua sắm ngay
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
