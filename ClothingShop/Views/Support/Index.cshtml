@model List<ClothingShop.Models.SupportTicket>
@{
    ViewData["Title"] = "Hỗ trợ khách hàng";
}

<div class="container py-5" style="padding-bottom: 100px !important;">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold mb-1">
                        <i class="fas fa-headset me-2"></i>Yêu cầu hỗ trợ của bạn
                    </h2>
                    <p class="text-muted mb-0">Quản lý và theo dõi các yêu cầu hỗ trợ của bạn</p>
                </div>

                <!-- Chỉ để 1 nút này -->
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createTicketModal">
                    <i class="fas fa-plus-circle me-2"></i>Tạo yêu cầu mới
                </button>
            </div>

            <!-- Thông báo -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- Danh sách ticket -->
            @if (Model.Any())
            {
                <div class="card shadow-sm">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 border-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="px-4">Mã</th>
                                        <th>Tiêu đề</th>
                                        <th class="text-center">Trạng thái</th>
                                        <th class="text-center">Tin nhắn</th>
                                        <th>Ngày tạo</th>
                                        <th>Cập nhật</th>
                                        <th class="text-center">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ticket in Model)
                                    {
                                        <tr>
                                            <td class="px-4 fw-bold">#@ticket.Id</td>

                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <i class="fas fa-ticket-alt text-primary me-2"></i>
                                                    <span>@ticket.Subject</span>
                                                </div>
                                            </td>

                                            <td class="text-center">
                                                @if (ticket.Status == "Mở")
                                                {
                                                    <span class="badge bg-success">
                                                        <i class="fas fa-circle me-1" style="font-size: 0.5rem;"></i>@ticket.Status
                                                    </span>
                                                }
                                                else if (ticket.Status == "Đang xử lý")
                                                {
                                                    <span class="badge bg-warning text-dark">
                                                        <i class="fas fa-circle me-1" style="font-size: 0.5rem;"></i>@ticket.Status
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">
                                                        <i class="fas fa-circle me-1" style="font-size: 0.5rem;"></i>@ticket.Status
                                                    </span>
                                                }
                                            </td>

                                            <td class="text-center">
                                                <span class="badge bg-light text-dark">
                                                    <i class="fas fa-comments me-1"></i>@ticket.Messages.Count
                                                </span>
                                            </td>

                                            <td>
                                                <small class="text-muted">
                                                    <i class="far fa-calendar me-1"></i>
                                                    @ticket.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                                </small>
                                            </td>

                                            <td>
                                                <small class="text-muted">
                                                    @if (ticket.UpdatedAt.HasValue)
                                                    {
                                                        <span>
                                                            <i class="far fa-clock me-1"></i>
                                                            @ticket.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span>-</span>
                                                    }
                                                </small>
                                            </td>

                                            <td class="text-center">
                                                <a href="@Url.Action("Details", new { id = ticket.Id })"
                                                   class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-eye me-1"></i>Xem chi tiết
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <!-- Không có ticket -->
                <div class="card shadow-sm text-center py-5">
                    <div class="card-body">
                        <i class="fas fa-inbox fa-4x text-muted mb-3"></i>
                        <h5 class="mb-2">Chưa có yêu cầu hỗ trợ</h5>
                        <p class="text-muted mb-4">Bạn chưa có yêu cầu hỗ trợ nào. Hãy tạo yêu cầu mới để được hỗ trợ.</p>

                        <!-- Không còn nút bị dư nữa -->
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@await Html.PartialAsync("_CreateSupportTicketModal")

@section Scripts {
    @await Html.PartialAsync("_ModalScripts")
}
