@model List<ClothingShop.Models.SupportTicket>
@{
    ViewData["Title"] = "Quản lý hỗ trợ khách hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Quản lý hỗ trợ khách hàng</h2>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<!-- Bộ lọc -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Trạng thái</label>
                <select name="status" class="form-select">
                    <option value="">Tất cả</option>
                    <option value="Mở" selected="@(ViewBag.Status == "Mở")">Mở</option>
                    <option value="Đang xử lý" selected="@(ViewBag.Status == "Đang xử lý")">Đang xử lý</option>
                    <option value="Đã đóng" selected="@(ViewBag.Status == "Đã đóng")">Đã đóng</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Tìm kiếm</label>
                <input type="text" name="search" class="form-control" 
                       value="@ViewBag.Search" placeholder="Mã ticket, tiêu đề, tên khách hàng...">
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-primary me-2">
                    <i class="bi bi-search"></i> Tìm kiếm
                </button>
                <a href="/Admin/Support" class="btn btn-secondary">
                    <i class="bi bi-arrow-clockwise"></i> Reset
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Thống kê nhanh -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-success">
            <div class="card-body">
                <h5>Mở</h5>
                <h3>@Model.Count(t => t.Status == "Mở")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-warning">
            <div class="card-body">
                <h5>Đang xử lý</h5>
                <h3>@Model.Count(t => t.Status == "Đang xử lý")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-secondary">
            <div class="card-body">
                <h5>Đã đóng</h5>
                <h3>@Model.Count(t => t.Status == "Đã đóng")</h3>
            </div>
        </div>
    </div>
</div>

<!-- Danh sách ticket -->
@if (Model.Any())
{
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Mã</th>
                            <th>Khách hàng</th>
                            <th>Tiêu đề</th>
                            <th>Trạng thái</th>
                            <th>Tin nhắn</th>
                            <th>Ngày tạo</th>
                            <th>Cập nhật</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ticket in Model)
                        {
                            <tr>
                                <td><strong>#@ticket.Id</strong></td>
                                <td>
                                    @ticket.User?.FullName<br>
                                    <small class="text-muted">@ticket.User?.Email</small>
                                </td>
                                <td>@ticket.Subject</td>
                                <td>
                                    @if (ticket.Status == "Mở")
                                    {
                                        <span class="badge bg-success">@ticket.Status</span>
                                    }
                                    else if (ticket.Status == "Đang xử lý")
                                    {
                                        <span class="badge bg-warning">@ticket.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@ticket.Status</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-info">@ticket.Messages.Count</span>
                                </td>
                                <td>@ticket.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@(ticket.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                                <td>
                                    <a href="/Admin/Support/Details/@ticket.Id" 
                                       class="btn btn-sm btn-primary">
                                        <i class="bi bi-eye"></i> Xem
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Phân trang -->
            @if (ViewBag.TotalPages > 1)
            {
                <nav class="mt-3">
                    <ul class="pagination justify-content-center">
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                <a class="page-link" href="?page=@i&status=@ViewBag.Status&search=@ViewBag.Search">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>
    </div>
}
else
{
    <div class="alert alert-info">
        Không có yêu cầu hỗ trợ nào.
    </div>
}
